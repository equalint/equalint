{
  "name": "equalint-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "equalint-monorepo",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@equalint/config": {
      "resolved": "packages/config",
      "link": true
    },
    "node_modules/@equalint/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@equalint/reporters": {
      "resolved": "packages/reporters",
      "link": true
    },
    "node_modules/equalint": {
      "resolved": "packages/equalint",
      "link": true
    },
    "packages/config": {
      "name": "@equalint/config",
      "version": "0.0.1",
      "license": "AGPL-3.0-only"
    },
    "packages/core": {
      "name": "@equalint/core",
      "version": "0.0.1",
      "license": "AGPL-3.0-only"
    },
    "packages/equalint": {
      "version": "0.0.1",
      "license": "AGPL-3.0-only",
      "dependencies": {
        "@equalint/config": "*",
        "@equalint/core": "*",
        "@equalint/reporters": "*"
      },
      "bin": {
        "equalint": "bin/equalint.js"
      }
    },
    "packages/reporters": {
      "name": "@equalint/reporters",
      "version": "0.0.1",
      "license": "AGPL-3.0-only"
    }
  }
}
